# Copy to .env and fill in real values. .env is gitignored (Hard Constraint #1).
# This file documents the required variable NAMES only — no real secrets here.

# OpenRouter API key, used to authenticate the rankings-daily pull.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Electricity Maps API token (used from Phase 3 onward; free tier is non-commercial).
# https://app.electricitymaps.com/developer-hub
# Canonical name read by pipeline/config.py and CI — must match exactly.
ELECTRICITYMAPS_API_KEY=
