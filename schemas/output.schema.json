{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "Range": {
      "type": "object",
      "required": ["low", "mid", "high"],
      "properties": {
        "low": { "type": "number" },
        "mid": { "type": "number" },
        "high": { "type": "number" }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "methodology_version",
    "generated_at",
    "data_date",
    "source_citation",
    "scope_note",
    "assumptions",
    "sources",
    "models",
    "totals"
  ],
  "properties": {
    "methodology_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "data_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "source_citation": { "type": "string" },
    "scope_note": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "publisher", "url", "version", "accessed"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "publisher": { "type": "string" },
          "url": { "type": "string" },
          "version": { "type": "string" },
          "accessed": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "assumptions": {
      "type": "object",
      "required": ["input_output_ratio"],
      "properties": {
        "input_output_ratio": { "type": "string" },
        "default_pue": { "type": "number" },
        "pue_band": { "type": "string" },
        "prefill_alpha": { "type": "string" },
        "embodied_ratio_of_operational": { "type": "string" },
        "water_l_per_kwh": { "type": "string" }
      },
      "additionalProperties": false
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slug",
          "display_name",
          "origin",
          "open_or_closed",
          "total_tokens",
          "est_output_tokens",
          "wh_per_output_token",
          "energy_kwh",
          "energy_source",
          "energy_source_id",
          "region",
          "carbon_intensity_gco2_kwh",
          "grid_source",
          "grid_source_id",
          "pue",
          "co2_kg",
          "co2_kg_embodied",
          "co2_kg_total",
          "renewable_match_pct",
          "co2_kg_market",
          "wue",
          "water_liters",
          "flags"
        ],
        "properties": {
          "slug": { "type": "string" },
          "display_name": { "type": "string" },
          "origin": { "enum": ["CN", "US", "EU", "OTHER"] },
          "open_or_closed": { "enum": ["open", "closed"] },
          "total_tokens": { "type": "integer" },
          "est_output_tokens": { "type": "integer" },
          "wh_per_output_token": { "$ref": "#/definitions/Range" },
          "energy_kwh": { "$ref": "#/definitions/Range" },
          "energy_source": {
            "enum": ["ai_energy_score", "ecologits", "parameter_class_fallback"]
          },
          "energy_source_id": { "type": "string" },
          "region": { "type": "string" },
          "carbon_intensity_gco2_kwh": { "type": "number" },
          "grid_source": { "enum": ["electricity_maps_live", "eia_live", "annual_factor"] },
          "grid_source_id": { "type": "string" },
          "pue": { "type": "number" },
          "co2_kg": { "$ref": "#/definitions/Range" },
          "co2_kg_embodied": { "$ref": "#/definitions/Range" },
          "co2_kg_total": { "$ref": "#/definitions/Range" },
          "renewable_match_pct": { "type": ["number", "null"] },
          "co2_kg_market": { "$ref": "#/definitions/Range" },
          "wue": { "type": "number" },
          "water_liters": { "$ref": "#/definitions/Range" },
          "flags": {
            "type": "array",
            "items": {
              "enum": [
                "UNKNOWN_MODEL",
                "UNMAPPED_SLUG",
                "FALLBACK_ENERGY_CLASS",
                "FALLBACK_GRID_ANNUAL",
                "CLOSED_MODEL_ASSUMED",
                "IDLE_INCLUDED",
                "MARKET_RESIDUAL_FLOOR"
              ]
            }
          }
        },
        "additionalProperties": false
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "total_tokens",
        "uncovered_tokens",
        "modeled_traffic_fraction",
        "precision",
        "mapped_traffic_fraction",
        "unmapped_tokens",
        "unmapped_traffic_fraction",
        "unmapped_slugs",
        "est_output_tokens",
        "energy_kwh",
        "co2_kg",
        "co2_kg_embodied",
        "co2_kg_total",
        "co2_kg_market",
        "water_liters",
        "by_origin",
        "by_open_closed"
      ],
      "properties": {
        "total_tokens": { "type": "integer" },
        "uncovered_tokens": { "type": "integer" },
        "modeled_traffic_fraction": { "type": "number" },
        "precision": {
          "type": "object",
          "required": [
            "energy_measured_fraction",
            "energy_class_fallback_fraction",
            "grid_live_fraction",
            "grid_annual_fallback_fraction",
            "models_measured",
            "models_total",
            "grid_live_models"
          ],
          "properties": {
            "energy_measured_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
            "energy_class_fallback_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
            "grid_live_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
            "grid_annual_fallback_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
            "models_measured": { "type": "integer", "minimum": 0 },
            "models_total": { "type": "integer", "minimum": 0 },
            "grid_live_models": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "mapped_traffic_fraction": { "type": "number" },
        "unmapped_tokens": { "type": "integer" },
        "unmapped_traffic_fraction": { "type": "number" },
        "unmapped_slugs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["slug", "total_tokens"],
            "properties": {
              "slug": { "type": "string" },
              "total_tokens": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "est_output_tokens": { "type": "integer" },
        "energy_kwh": { "$ref": "#/definitions/Range" },
        "co2_kg": { "$ref": "#/definitions/Range" },
        "co2_kg_independent": { "$ref": "#/definitions/Range" },
        "co2_kg_embodied": { "$ref": "#/definitions/Range" },
        "co2_kg_total": { "$ref": "#/definitions/Range" },
        "co2_kg_market": { "$ref": "#/definitions/Range" },
        "water_liters": { "$ref": "#/definitions/Range" },
        "by_origin": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["co2_kg", "co2_kg_market", "water_liters"],
            "properties": {
              "co2_kg": { "$ref": "#/definitions/Range" },
              "co2_kg_market": { "$ref": "#/definitions/Range" },
              "water_liters": { "$ref": "#/definitions/Range" }
            },
            "additionalProperties": false
          }
        },
        "by_open_closed": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["co2_kg", "co2_kg_market", "water_liters"],
            "properties": {
              "co2_kg": { "$ref": "#/definitions/Range" },
              "co2_kg_market": { "$ref": "#/definitions/Range" },
              "water_liters": { "$ref": "#/definitions/Range" }
            },
            "additionalProperties": false
          }
        },
        "tiers": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "fairness": {
          "type": "object",
          "properties": {
            "rank_stability": {
              "type": "object",
              "properties": {
                "by_co2": {
                  "type": "object",
                  "required": ["top_n", "ranks_changed", "max_displacement"],
                  "properties": {
                    "top_n": { "type": "integer", "minimum": 0 },
                    "ranks_changed": { "type": "integer", "minimum": 0 },
                    "max_displacement": { "type": "integer", "minimum": 0 }
                  },
                  "additionalProperties": false
                },
                "by_efficiency": {
                  "type": "object",
                  "required": ["top_n", "ranks_changed", "max_displacement"],
                  "properties": {
                    "top_n": { "type": "integer", "minimum": 0 },
                    "ranks_changed": { "type": "integer", "minimum": 0 },
                    "max_displacement": { "type": "integer", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "unweighted": {
              "type": "object",
              "properties": {
                "co2_kg": { "$ref": "#/definitions/Range" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
